{
  "name": "react-native-motion",
  "version": "0.1.0",
  "description": "A curated set of animation presets for React Native, powered by Reanimated",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "!**/__tests__"
  ],
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf lib",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "animation",
    "motion",
    "presets",
    "spring",
    "reanimated"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nathanke/react-native-motion.git"
  },
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-reanimated": ">=3.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "react-native": "^0.74.0",
    "react-native-reanimated": "^3.8.0",
    "react-native-builder-bob": "^0.23.0",
    "typescript": "^5.3.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
